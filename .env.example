# ============================================
# Unique Driftwood Creations - Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# Gmail SMTP Configuration
# Create an App Password at: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Where inquiry notification emails are sent
NOTIFICATION_EMAIL=camebloon@gmail.com

# Admin Dashboard Password
ADMIN_PASSWORD=choose-a-strong-password

# JWT Secret (use any long random string)
JWT_SECRET=replace-with-a-random-secret-string-at-least-32-chars

# Database (auto-configured when you add Vercel Postgres in dashboard)
# POSTGRES_URL is set automatically by Vercel — do not set manually
